{
  "name": "openapi-collection-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Local-first desktop REST API collection editor for OpenAPI and Swagger imports.",
  "author": "GatewayLabs (https://gatewaylabs.net)",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Gatewaylabsnet/specfold",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gatewaylabsnet/specfold.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @openapi-collection-studio/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "package:win:portable": "npm run package:win:portable --workspace @openapi-collection-studio/desktop",
    "package:win:installer": "npm run package:win:installer --workspace @openapi-collection-studio/desktop",
    "package:win": "npm run package:win --workspace @openapi-collection-studio/desktop",
    "package:mac": "npm run package:mac --workspace @openapi-collection-studio/desktop",
    "package:linux": "npm run package:linux --workspace @openapi-collection-studio/desktop"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
