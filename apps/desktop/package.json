{
  "name": "@openapi-collection-studio/desktop",
  "version": "0.2.1",
  "private": true,
  "description": "Desktop shell for Specfold.",
  "author": "GatewayLabs (https://gatewaylabs.net)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "build": "electron-vite build",
    "package:win:portable": "npm run build && electron-builder --win portable --x64 -p never",
    "package:win:installer": "npm run build && electron-builder --win nsis --x64 -p never",
    "package:win": "npm run build && electron-builder --win nsis portable --x64 -p never",
    "icon": "node build/generate-icon.mjs"
  },
  "devDependencies": {
    "@openapi-collection-studio/core": "0.2.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "net.gatewaylabs.specfold",
    "productName": "Specfold",
    "electronVersion": "31.7.7",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/icon.png",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
